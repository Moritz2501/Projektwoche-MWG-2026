<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projekte - Projektwoche MWG 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .glass-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .table-glass {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .table-glass thead {
            background: rgba(255, 255, 255, 0.05);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .table-glass tbody tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }

        .table-glass tbody tr:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .btn-primary {
            background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
            color: white;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s ease;
            border: 1px solid rgba(124, 58, 237, 0.5);
            text-decoration: none;
            display: inline-block;
            border-radius: 0.5rem;
        }

        .btn-primary:hover {
            box-shadow: 0 0 30px rgba(124, 58, 237, 0.4);
            transform: translateY(-2px);
        }

        .badge-booth {
            background: rgba(59, 130, 246, 0.2);
            color: #93c5fd;
            padding: 0.25rem 0.75rem;
            font-size: 0.75rem;
            border: 1px solid rgba(59, 130, 246, 0.5);
        }

        .badge-stage {
            background: rgba(168, 85, 247, 0.2);
            color: #d8b4fe;
            padding: 0.25rem 0.75rem;
            font-size: 0.75rem;
            border: 1px solid rgba(168, 85, 247, 0.5);
        }
    </style>
</head>
<body>
</body>
</html>

<!-- Content -->
<div>
    <div class="page-header mb-8">
        <div>
            <h1 class="page-title text-4xl font-bold mb-2">📋 Projekte</h1>
            <p class="page-subtitle">Übersicht aller teilnehmenden Schulprojekte</p>
        </div>
        <div class="page-actions">
            <a href="/dashboard" class="back-home-link">🏠 Dashboard</a>
            <% if (user) { %>
                <% if (user.role === 'admin') { %>
                    <a href="/projekte/batch" class="btn-primary" style="background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%); border-color: rgba(124, 58, 237, 0.5);">
                        📚 Mehrere Projekte
                    </a>
                <% } %>
                <a href="/projekte/neu" class="btn-primary">
                    ➕ Neues Projekt
                </a>
            <% } %>
        </div>
    </div>

    <% if (projects && projects.length > 0) { %>
        <div class="glass-panel p-6 overflow-x-auto">
            <table class="table-glass w-full">
                <thead>
                    <tr class="text-left">
                        <th class="px-4 py-3 font-semibold">Projektname</th>
                        <th class="px-4 py-3 font-semibold">Beschreibung</th>
                        <th class="px-4 py-3 font-semibold">Betreuer</th>
                        <th class="px-4 py-3 font-semibold">Teilnehmer</th>
                        <th class="px-4 py-3 font-semibold">Präsentation</th>
                        <% if (user) { %>
                            <th class="px-4 py-3 font-semibold">Aktionen</th>
                        <% } %>
                    </tr>
                </thead>
                <tbody>
                    <% projects.forEach(project => { %>
                        <tr>
                            <td class="px-4 py-3 font-medium text-white"><%= project.name %></td>
                            <td class="px-4 py-3 text-gray-300 text-sm"><%= project.description.substring(0, 50) %>...</td>
                            <td class="px-4 py-3 text-gray-300 text-sm">
                                <% if (project.supervisors && project.supervisors.length > 0) { %>
                                    <%= project.supervisors.join(', ') %>
                                <% } else { %>
                                    <span class="text-gray-500">-</span>
                                <% } %>
                            </td>
                            <td class="px-4 py-3 text-gray-300">
                                👥 <%= project.memberCount %>
                            </td>
                            <td class="px-4 py-3">
                                <% if (project.presentationType === 'booth') { %>
                                    <span class="badge-booth">🏪 Stand</span>
                                <% } else { %>
                                    <span class="badge-stage">🎭 Bühne</span>
                                <% } %>
                            </td>
                            <% if (user) { %>
                                <td class="px-4 py-3">
                                    <div class="flex items-center gap-3">
                                        <a href="/projekte/<%= project.id %>/edit" class="text-purple-400 hover:text-purple-300 text-sm">
                                            ✏️ Bearbeiten
                                        </a>
                                        <button type="button" onclick="deleteProject('<%= project.id %>', '<%= project.name.replace(/'/g, "\\'") %>')" class="text-red-400 hover:text-red-300 text-sm">
                                            🗑️ Löschen
                                        </button>
                                    </div>
                                </td>
                            <% } %>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="glass-panel p-12 text-center">
            <p class="text-gray-400 text-lg mb-4">
                📭 Noch keine Projekte vorhanden
            </p>
            <% if (user) { %>
                <a href="/projekte/neu" class="btn-primary">
                    ➕ Erstes Projekt erstellen
                </a>
            <% } %>
        </div>
    <% } %>

    <!-- Stats Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
        <div class="glass-panel p-6">
            <p class="text-gray-400 text-sm">Gesamtprojekte</p>
            <p class="text-4xl font-bold text-white mt-2"><%= projects ? projects.length : 0 %></p>
        </div>
        <div class="glass-panel p-6">
            <p class="text-gray-400 text-sm">Stand-Präsentationen</p>
            <p class="text-4xl font-bold text-white mt-2"><%= projects ? projects.filter(p => p.presentationType === 'booth').length : 0 %></p>
        </div>
        <div class="glass-panel p-6">
            <p class="text-gray-400 text-sm">Bühnen-Präsentationen</p>
            <p class="text-4xl font-bold text-white mt-2"><%= projects ? projects.filter(p => p.presentationType === 'stage-time-slot').length : 0 %></p>
        </div>
    </div>
</div>

<script>
    async function deleteProject(projectId, projectName) {
        if (!confirm(`Soll das Projekt "${projectName}" wirklich gelöscht werden?`)) {
            return;
        }

        try {
            const response = await fetch(`/api/projects/${projectId}`, {
                method: 'DELETE'
            });

            if (response.ok) {
                location.reload();
            } else {
                const data = await response.json().catch(() => ({}));
                alert(data.error || 'Fehler beim Löschen des Projekts');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Ein Fehler ist aufgetreten');
        }
    }
</script>
