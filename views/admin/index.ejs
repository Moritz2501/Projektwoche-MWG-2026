<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verwaltung - Projektwoche MWG 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * {
            border-radius: 0 !important;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .table-glass {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .table-glass thead {
            background: rgba(255, 255, 255, 0.05);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .table-glass tbody tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .table-glass tbody tr:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .btn-primary {
            background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
            color: white;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s ease;
            border: 1px solid rgba(124, 58, 237, 0.5);
            border-radius: 0.5rem;
        }

        .btn-primary:hover {
            box-shadow: 0 0 30px rgba(124, 58, 237, 0.4);
        }

        .input-field {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #e5e7eb;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }

        .input-field:focus {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(124, 58, 237, 0.5);
            outline: none;
        }

        .success-badge {
            background: rgba(34, 197, 94, 0.2);
            color: #86efac;
            padding: 0.25rem 0.75rem;
            font-size: 0.75rem;
            border: 1px solid rgba(34, 197, 94, 0.5);
        }

        .log-action-create {
            color: #86efac;
        }

        .log-action-update {
            color: #fbbf24;
        }

        .log-action-delete {
            color: #f87171;
        }

        .log-action-login {
            color: #60a5fa;
        }
    </style>
</head>
<body>
</body>
</html>

<!-- Content -->
<div>
    <div class="page-header mb-8">
        <div>
            <h1 class="page-title text-4xl font-bold mb-2">Verwaltung</h1>
            <p class="page-subtitle">Systemverwaltung und Benutzermenagement</p>
        </div>
        <div class="page-actions">
            <a href="/dashboard" class="back-home-link">Dashboard</a>
        </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-4 mb-8 border-b border-white/10">
        <button onclick="switchTab('users')" class="tab-btn active px-4 py-2 border-b-2 border-purple-500 text-purple-400">
            Benutzer
        </button>
        <button onclick="switchTab('logs')" class="tab-btn px-4 py-2 text-gray-400 hover:text-white">
            Systemlogs
        </button>
    </div>

    <!-- Users Tab -->
    <div id="users-tab" class="tab-content">
        <div class="mb-8">
            <div class="glass-panel p-6">
                <h3 class="text-lg font-semibold text-white mb-4">Feste Konten</h3>
                <p class="text-gray-400 mb-4">
                    Es stehen nur die beiden festen Rollen <span class="text-purple-300 font-semibold">admin</span> und <span class="text-purple-300 font-semibold">user</span> zur Verfügung.
                    Die Passwörter werden über die Umgebungsvariablen <span class="text-gray-200 font-mono">ADMIN_PASS</span> und <span class="text-gray-200 font-mono">USER_PASS</span> gesetzt.
                </p>
            </div>
        </div>

        <!-- Users Table -->
        <div class="glass-panel p-6 overflow-x-auto">
            <h3 class="text-lg font-semibold text-white mb-4">Benutzer</h3>
            <% if (users && users.length > 0) { %>
                <table class="table-glass w-full">
                    <thead>
                        <tr class="text-left">
                            <th class="px-4 py-3 font-semibold">Email</th>
                            <th class="px-4 py-3 font-semibold">Rolle</th>
                            <th class="px-4 py-3 font-semibold">Erstellt am</th>
                            <th class="px-4 py-3 font-semibold">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(user => { %>
                            <tr>
                                <td class="px-4 py-3 text-gray-300"><%= user.email %></td>
                                <td class="px-4 py-3 capitalize text-purple-300"><%= user.role %></td>
                                <td class="px-4 py-3 text-gray-300 text-sm">
                                    <%= new Date(user.createdAt).toLocaleDateString('de-DE') %>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="success-badge">Aktiv</span>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p class="text-gray-400">Keine Benutzer vorhanden</p>
            <% } %>
        </div>
    </div>

    <!-- Logs Tab -->
    <div id="logs-tab" class="tab-content" style="display: none;">
        <div class="glass-panel p-6 overflow-x-auto">
            <h3 class="text-lg font-semibold text-white mb-4">Systemlogs (letzte 100)</h3>
            <% if (logs && logs.length > 0) { %>
                <table class="table-glass w-full text-sm">
                    <thead>
                        <tr class="text-left">
                            <th class="px-4 py-3 font-semibold">Zeitstempel</th>
                            <th class="px-4 py-3 font-semibold">Aktion</th>
                            <th class="px-4 py-3 font-semibold">Benutzer-ID</th>
                            <th class="px-4 py-3 font-semibold">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% logs.forEach(log => { %>
                            <tr>
                                <td class="px-4 py-3 text-gray-400">
                                    <%= new Date(log.timestamp).toLocaleString('de-DE') %>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="log-action-<%= log.action.split('_')[0] %>">
                                        <%= log.action %>
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-gray-400 font-mono text-xs">
                                    <%= log.userId %>
                                </td>
                                <td class="px-4 py-3 text-gray-400 text-xs">
                                    <%= log.details %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p class="text-gray-400">Keine Logs vorhanden</p>
            <% } %>
        </div>
    </div>

    <!-- Info Section -->
    <div class="glass-panel p-6 mt-8">
        <h3 class="text-lg font-semibold text-white mb-3">ℹ️ System-Informationen</h3>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <p class="text-xs text-gray-400">Gesamtbenutzer</p>
                <p class="text-3xl font-bold text-purple-300"><%= users ? users.length : 0 %></p>
            </div>
            <div>
                <p class="text-xs text-gray-400">Systemlogs</p>
                <p class="text-3xl font-bold text-purple-300"><%= logs ? logs.length : 0 %></p>
            </div>
            <div>
                <p class="text-xs text-gray-400">Status</p>
                <p class="text-sm text-green-400">Online</p>
            </div>
            <div>
                <p class="text-xs text-gray-400">Letzte Aktivität</p>
                <p class="text-sm text-gray-300">
                    <% if (logs && logs.length > 0) { %>
                        <%= new Date(logs[0].timestamp).toLocaleTimeString('de-DE') %>
                    <% } else { %>
                        Keine
                    <% } %>
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(tab) {
        // Hide all tabs
        document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
        document.querySelectorAll('.tab-btn').forEach(b => {
            b.classList.remove('active');
            b.style.borderColor = 'transparent';
            b.style.color = '#9ca3af';
        });

        // Show selected tab
        document.getElementById(tab + '-tab').style.display = 'block';
        event.target.classList.add('active');
        event.target.style.borderColor = '#7c3aed';
        event.target.style.color = '#a78bfa';
    }

</script>
