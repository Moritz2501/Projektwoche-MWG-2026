<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kanban Board - Projektwoche MWG 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .glass-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.75rem;
        }

        .kanban-column {
            flex: 1;
            min-width: 300px;
            padding: 1.5rem;
            border-top: 4px solid;
            border-radius: 0.75rem;
        }

        .column-todo {
            background: rgba(220, 38, 38, 0.08);
            border-top-color: #dc2626;
            border: 1px solid rgba(220, 38, 38, 0.2);
        }

        .column-inprogress {
            background: rgba(202, 138, 4, 0.08);
            border-top-color: #ca8a04;
            border: 1px solid rgba(202, 138, 4, 0.2);
        }

        .column-done {
            background: rgba(34, 197, 94, 0.08);
            border-top-color: #22c55e;
            border: 1px solid rgba(34, 197, 94, 0.2);
        }

        .task-card {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1rem;
            margin-bottom: 1rem;
            cursor: grab;
            transition: all 0.3s ease;
            border-radius: 0.375rem;
            user-select: none;
        }

        .task-card:hover {
            background: rgba(255, 255, 255, 0.12);
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(124, 58, 237, 0.2);
        }

        .task-card:active {
            cursor: grabbing;
        }

        .btn-primary {
            background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
            color: white;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s ease;
            border: 1px solid rgba(124, 58, 237, 0.5);
        }

        .btn-primary:hover {
            box-shadow: 0 0 30px rgba(124, 58, 237, 0.4);
        }

        .input-field {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #e5e7eb;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }

        .input-field:focus {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(124, 58, 237, 0.5);
            outline: none;
        }

        .drop-zone {
            min-height: 200px;
            border: 2px dashed rgba(255, 255, 255, 0.1);
            padding: 1rem;
            border-radius: 0;
        }

        .drop-zone.active {
            background: rgba(124, 58, 237, 0.1);
            border-color: rgba(124, 58, 237, 0.5);
        }
    </style>
</head>
<body>
</body>
</html>

<!-- Content -->
<div>
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-4xl font-bold text-white mb-2">📌 Kanban Board</h1>
            <p class="text-gray-400">Verwalte Aufgaben in Spalten</p>
        </div>
    </div>

    <!-- Add Task Form -->
    <div class="glass-panel p-6 mb-8">
        <h3 class="text-lg font-semibold text-white mb-4">➕ Neue Aufgabe</h3>
        <form onsubmit="createTask(event)" class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm text-gray-300 mb-2">Titel</label>
                <input type="text" id="taskTitle" class="input-field w-full" placeholder="Aufgabe..." required>
            </div>
            <div>
                <label class="block text-sm text-gray-300 mb-2">Beschreibung</label>
                <input type="text" id="taskDesc" class="input-field w-full" placeholder="Details...">
            </div>
            <div>
                <label class="block text-sm text-gray-300 mb-2">Spalte</label>
                <select id="taskColumn" class="input-field w-full" required>
                    <option value="todo">Zu erledigen</option>
                    <option value="inprogress">In Bearbeitung</option>
                    <option value="done">Erledigt</option>
                </select>
            </div>
            <div class="flex items-end">
                <button type="submit" class="btn-primary w-full">
                    ✅ Erstellen
                </button>
            </div>
        </form>
    </div>

    <!-- Kanban Board -->
    <div class="flex gap-6 overflow-x-auto pb-4">
        <!-- To Do Column -->
        <div class="kanban-column column-todo">
            <h2 class="text-lg font-bold text-red-300 mb-4">Zu erledigen ❌</h2>
            <div class="drop-zone" ondrop="handleDrop(event, 'todo')" ondragover="allowDrop(event)" ondragleave="clearDrop(event)">
                <% todoTasks.forEach(task => { %>
                    <div class="task-card" draggable="true" data-task-id="<%= task.id %>" ondragstart="startDrag(event)">
                        <h4 class="text-sm font-semibold text-white"><%= task.title %></h4>
                        <% if (task.description) { %>
                            <p class="text-xs text-gray-400 mt-1"><%= task.description %></p>
                        <% } %>
                        <div class="mt-2 flex justify-between items-center">
                            <span class="text-xs text-gray-500"><%= new Date(task.createdAt).toLocaleDateString('de-DE') %></span>
                            <button onclick="deleteTask('<%= task.id %>')" class="text-xs text-red-400 hover:text-red-300">🗑️</button>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>

        <!-- In Progress Column -->
        <div class="kanban-column column-inprogress">
            <h2 class="text-lg font-bold text-yellow-300 mb-4">In Bearbeitung ⚙️</h2>
            <div class="drop-zone" ondrop="handleDrop(event, 'inprogress')" ondragover="allowDrop(event)" ondragleave="clearDrop(event)">
                <% inProgressTasks.forEach(task => { %>
                    <div class="task-card" draggable="true" data-task-id="<%= task.id %>" ondragstart="startDrag(event)">
                        <h4 class="text-sm font-semibold text-white"><%= task.title %></h4>
                        <% if (task.description) { %>
                            <p class="text-xs text-gray-400 mt-1"><%= task.description %></p>
                        <% } %>
                        <div class="mt-2 flex justify-between items-center">
                            <span class="text-xs text-gray-500"><%= new Date(task.createdAt).toLocaleDateString('de-DE') %></span>
                            <button onclick="deleteTask('<%= task.id %>')" class="text-xs text-red-400 hover:text-red-300">🗑️</button>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>

        <!-- Done Column -->
        <div class="kanban-column column-done">
            <h2 class="text-lg font-bold text-green-300 mb-4">Erledigt ✅</h2>
            <div class="drop-zone" ondrop="handleDrop(event, 'done')" ondragover="allowDrop(event)" ondragleave="clearDrop(event)">
                <% doneTasks.forEach(task => { %>
                    <div class="task-card" draggable="true" data-task-id="<%= task.id %>" ondragstart="startDrag(event)">
                        <h4 class="text-sm font-semibold text-white"><%= task.title %></h4>
                        <% if (task.description) { %>
                            <p class="text-xs text-gray-400 mt-1"><%= task.description %></p>
                        <% } %>
                        <div class="mt-2 flex justify-between items-center">
                            <span class="text-xs text-gray-500"><%= new Date(task.createdAt).toLocaleDateString('de-DE') %></span>
                            <button onclick="deleteTask('<%= task.id %>')" class="text-xs text-red-400 hover:text-red-300">🗑️</button>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>
</div>

<script>
    let draggedTaskId = null;

    function startDrag(event) {
        draggedTaskId = event.target.closest('.task-card').dataset.taskId;
        event.dataTransfer.effectAllowed = 'move';
    }

    function allowDrop(event) {
        event.preventDefault();
        event.dataTransfer.dropEffect = 'move';
        event.target.closest('.drop-zone')?.classList.add('active');
    }

    function clearDrop(event) {
        event.target.closest('.drop-zone')?.classList.remove('active');
    }

    async function handleDrop(event, column) {
        event.preventDefault();
        event.target.closest('.drop-zone')?.classList.remove('active');

        if (!draggedTaskId) return;

        try {
            const response = await fetch(`/api/kanban/tasks/${draggedTaskId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ column })
            });

            if (response.ok) {
                location.reload();
            }
        } catch (error) {
            console.error('Error:', error);
        }
    }

    async function createTask(event) {
        event.preventDefault();

        const title = document.getElementById('taskTitle').value;
        const description = document.getElementById('taskDesc').value;
        const column = document.getElementById('taskColumn').value;

        try {
            const response = await fetch('/api/kanban/tasks', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title, description, column })
            });

            if (response.ok) {
                location.reload();
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Fehler beim Erstellen der Aufgabe');
        }
    }

    async function deleteTask(taskId) {
        if (!confirm('Aufgabe wirklich löschen?')) return;

        try {
            const response = await fetch(`/api/kanban/tasks/${taskId}`, {
                method: 'DELETE'
            });

            if (response.ok) {
                location.reload();
            }
        } catch (error) {
            console.error('Error:', error);
        }
    }
</script>
