<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Zeitplan - Projektwoche MWG 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --color-dark-base: #0a0f1e;
            --color-deep-purple: #2d0a4e;
        }

        body {
            background: linear-gradient(135deg, var(--color-dark-base) 0%, #1a1f3a 50%, var(--color-deep-purple) 100%);
            color: #e5e7eb;
            font-family: 'Inter', system-ui, sans-serif;
            min-height: 100vh;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
            color: white;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s ease;
            border: 1px solid rgba(124, 58, 237, 0.5);
            border-radius: 0.5rem;
        }

        .btn-primary:hover {
            box-shadow: 0 0 30px rgba(124, 58, 237, 0.4);
            transform: translateY(-2px);
        }

        .schedule-slot {
            background: #ffffff;
            border: 1px solid #d9c4bb;
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.3s ease;
            border-radius: 14px;
            color: #171312;
        }

        .schedule-slot:hover {
            background: #ffffff;
            box-shadow: 0 8px 22px rgba(111, 91, 86, 0.16);
        }

        .schedule-slot h3,
        .schedule-slot p,
        .schedule-slot .text-gray-300,
        .schedule-slot .text-gray-400,
        .schedule-slot .text-white {
            color: #171312 !important;
        }

        .time-badge {
            background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
            padding: 0.5rem 1rem;
            font-weight: bold;
            display: inline-block;
        }
    </style>
</head>
<body>
    <div class="min-h-screen p-8">
        <!-- Header -->
        <div class="max-w-4xl mx-auto mb-12">
            <div class="glass-panel hero-panel p-8 mb-8">
                <h1 class="text-4xl font-bold hero-title text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-purple-600 mb-2">
                    Projektwoche MWG 2026
                </h1>
                <p class="text-gray-300">Live Zeitplan und Informationen</p>
            </div>

            <div class="flex gap-4">
                <a href="/login" class="btn-primary">
                    Anmelden
                </a>
            </div>
        </div>

        <!-- Schedule Section -->
        <div class="max-w-4xl mx-auto">
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-white mb-6">Live Zeitplan</h2>

                <% if (slots && slots.length > 0) { %>
                    <div class="space-y-4">
                        <% slots.forEach(slot => {
                            const project = projects.find(p => p.id === slot.projectId);
                        %>
                            <div class="schedule-slot">
                                <div class="flex items-start justify-between">
                                    <div class="flex-1">
                                        <div class="time-badge mb-3">
                                                <%= slot.time %> (<%= slot.duration %> min)
                                        </div>
                                        <% if (project) { %>
                                            <h3 class="text-lg font-semibold text-white mt-3">
                                                <%= project.name %>
                                            </h3>
                                            <p class="text-gray-300 text-sm mt-1">
                                                <%= project.description %>
                                            </p>
                                            <% if (project.supervisors && project.supervisors.length > 0) { %>
                                                <p class="text-gray-400 text-xs mt-2">
                                                    Betreuer: <%= project.supervisors.join(', ') %>
                                                </p>
                                            <% } %>
                                        <% } else { %>
                                            <p class="text-gray-400 italic">
                                                - Noch kein Projekt zugeordnet -
                                            </p>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="glass-panel p-8 text-center">
                        <p class="text-gray-400">
                            Noch keine Zeitplan-Einträge vorhanden.
                        </p>
                    </div>
                <% } %>
            </div>

            <!-- Projects Section -->
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-white mb-6">Projekte</h2>

                <% if (projects && projects.length > 0) { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% projects.forEach(project => { %>
                            <div class="glass-panel dashboard-card p-6">
                                <h3 class="text-lg font-semibold text-white mb-2">
                                    <%= project.name %>
                                </h3>
                                <p class="text-gray-300 text-sm mb-3">
                                    <%= project.description %>
                                </p>
                                <div class="flex justify-between items-center">
                                    <span class="text-xs text-gray-400">
                                        <%= project.memberCount %> Teilnehmer
                                    </span>
                                    <span class="text-xs bg-purple-500/20 border border-purple-500/50 px-2 py-1 text-purple-300">
                                        <%= project.presentationType === 'booth' ? 'Stand' : 'Bühne' %>
                                    </span>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="glass-panel p-8 text-center">
                        <p class="text-gray-400">
                            Noch keine Projekte vorhanden.
                        </p>
                    </div>
                <% } %>
            </div>

            <!-- Info Box -->
            <div class="glass-panel p-8 text-center">
                <p class="text-gray-300 mb-4">
                    Diese Seite wird automatisch aktualisiert.
                </p>
                <p class="text-xs text-gray-500">
                    Letzte Aktualisierung: <%= new Date().toLocaleString('de-DE') %>
                </p>
            </div>
        </div>
    </div>

    <script>
        // Auto-refresh every 30 seconds
        setTimeout(() => {
            location.reload();
        }, 30000);
    </script>
</body>
</html>
