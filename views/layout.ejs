<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>Projektwoche MWG 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * {
            border-radius: 0 !important;
        }

        :root {
            --color-dark-base: #0a0f1e;
            --color-deep-purple: #2d0a4e;
            --color-accent: #7c3aed;
        }

        body {
            background: linear-gradient(135deg, var(--color-dark-base) 0%, #1a1f3a 50%, var(--color-deep-purple) 100%);
            color: #e5e7eb;
            font-family: 'Inter', system-ui, sans-serif;
            min-height: 100vh;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .glass-panel-dark {
            background: rgba(10, 15, 30, 0.4);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .glass-hover {
            transition: all 0.3s ease;
        }

        .glass-hover:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.15);
        }

        .glow-accent {
            box-shadow: 0 0 20px rgba(124, 58, 237, 0.2);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--color-accent) 0%, #6d28d9 100%);
            color: white;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s ease;
            border: 1px solid rgba(124, 58, 237, 0.5);
        }

        .btn-primary:hover {
            box-shadow: 0 0 30px rgba(124, 58, 237, 0.4);
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.1);
            color: #e5e7eb;
            padding: 0.75rem 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: all 0.3s ease;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.15);
            border-color: rgba(255, 255, 255, 0.3);
        }

        .text-highlight {
            color: #a78bfa;
            font-weight: 600;
        }

        .input-field {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #e5e7eb;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }

        .input-field:focus {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(124, 58, 237, 0.5);
            outline: none;
            box-shadow: 0 0 15px rgba(124, 58, 237, 0.2);
        }

        .input-field::placeholder {
            color: rgba(229, 231, 235, 0.4);
        }

        .table-glass {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .table-glass thead {
            background: rgba(255, 255, 255, 0.05);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .table-glass tbody tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }

        .table-glass tbody tr:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .nav-link {
            padding: 0.75rem 1.25rem;
            transition: all 0.3s ease;
            border-left: 3px solid transparent;
        }

        .nav-link:hover,
        .nav-link.active {
            background: rgba(255, 255, 255, 0.1);
            border-left-color: var(--color-accent);
            color: #a78bfa;
        }

        .column-todo {
            background: rgba(220, 38, 38, 0.1);
            border-top: 3px solid #dc2626;
        }

        .column-inprogress {
            background: rgba(202, 138, 4, 0.1);
            border-top: 3px solid #ca8a04;
        }

        .column-done {
            background: rgba(34, 197, 94, 0.1);
            border-top: 3px solid #22c55e;
        }

        .draggable {
            cursor: grab;
            transition: all 0.2s ease;
        }

        .draggable:active {
            cursor: grabbing;
            opacity: 0.7;
        }

        .error-badge {
            background: rgba(220, 38, 38, 0.2);
            border: 1px solid rgba(220, 38, 38, 0.5);
            color: #fca5a5;
        }

        .success-badge {
            background: rgba(34, 197, 94, 0.2);
            border: 1px solid rgba(34, 197, 94, 0.5);
            color: #86efac;
        }
    </style>
</head>
<body>
    <% if (isAuthenticated) { %>
        <div class="flex min-h-screen">
            <!-- Sidebar Navigation -->
            <nav class="w-64 glass-panel-dark border-r border-white/10 p-6 flex flex-col">
                <div class="mb-8">
                    <h1 class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-purple-600">
                        MWG 2026
                    </h1>
                    <p class="text-sm text-gray-400 mt-2">Projektwoche Management</p>
                </div>

                <div class="flex-1">
                    <div class="space-y-2">
                        <a href="/dashboard" class="nav-link block text-gray-300 hover:text-white">
                            📊 Dashboard
                        </a>
                        <a href="/projekte" class="nav-link block text-gray-300 hover:text-white">
                            📋 Projekte
                        </a>
                        <a href="/zeitplan" class="nav-link block text-gray-300 hover:text-white">
                            ⏰ Zeitplan
                        </a>
                        <% if (user && user.role === 'admin') { %>
                            <a href="/verwaltung" class="nav-link block text-gray-300 hover:text-white">
                                🔧 Verwaltung
                            </a>
                        <% } %>
                    </div>
                </div>

                <div class="border-t border-white/10 pt-4">
                    <a href="/dashboard" class="back-home-link w-full mb-3">🏠 Dashboard</a>
                    <div class="glass-panel p-4 mb-4">
                        <p class="text-xs text-gray-400">Benutzer</p>
                        <p class="text-sm font-semibold text-white mt-1"><%= user.username %></p>
                        <p class="text-xs text-purple-400 mt-1 capitalize"><%= user.role %></p>
                    </div>
                    <a href="/logout" class="btn-secondary w-full text-center block">
                        🚪 Abmelden
                    </a>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="flex-1 overflow-auto">
                <div class="p-8">
        </div>
    <% } %>

    <script>
        // Smooth transitions
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', (e) => {
                    if (link.href && !link.target && link.hostname === window.location.hostname) {
                        // Optional: Add transition effect
                    }
                });
            });
        });
    </script>
</body>
</html>
