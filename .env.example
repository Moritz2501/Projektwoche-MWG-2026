# Application Environment
NODE_ENV=development
PORT=3000

# Admin/User Credentials (MUST BE CHANGED IN PRODUCTION)
# Preferred: bcrypt hashes via ADMIN_PASS_HASH / USER_PASS_HASH
ADMIN_USER=admin
# ADMIN_PASS_HASH=<bcrypt_hash_here>
ADMIN_PASS=ChangeMe123!

USER_USER=user
# USER_PASS_HASH=<bcrypt_hash_here>
USER_PASS=user123

# Encryption Keys for AES-256-GCM
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_key_here_minimum_64_characters_required
ENCRYPTION_IV=your_16_byte_hex_key_here_minimum_32_characters_required

# Session Secret for express-session
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_secure_random_session_secret_here_minimum_32_characters_recommended
